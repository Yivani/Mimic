{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mimic",
  "version": "1.0.6",
  "identifier": "com.mimic.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mimic",
        "label": "main",
        "width": 1000,
        "height": 700,
        "minWidth": 840,
        "minHeight": 580,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Yivani/Mimic/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZGMEMxODE1MzA0QUIzNTMKUldSVHMwb3dGUmdNLzVyMC93bzlSdWdYRHdQdnNBdGJsSDJNT3JnRTFXcE1EYS8vbmVJaUxvL0MK"
    }
  }
}
